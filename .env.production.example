# === Application ===
RAILS_ENV=production
APP_HOST=tasker.example.com

# Docker image pulled by docker-compose.prod.yml
# Format: ghcr.io/<github-username>/<repo-name>:latest
APP_IMAGE=ghcr.io/your-github-username/nice_tasker:latest

# RAILS_MASTER_KEY — copy the content of config/master.key
# NEVER commit the real value; copy it to the server manually
RAILS_MASTER_KEY=

# === Puma ===
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# === Database ===
# DB_HOST and DB_PORT are set inline in docker-compose.prod.yml (postgres:5432)
# Set them here ONLY if using an external database
# DB_HOST=postgres
# DB_PORT=5432
DB_USER=nice_tasker
DB_PASSWORD=change_me_strong_password

# === OAuth — Google ===
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === OAuth — GitHub ===
# https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === OAuth — GitLab ===
# https://gitlab.com/-/profile/applications
GITLAB_APP_ID=
GITLAB_APP_SECRET=

# === Certbot ===
CERTBOT_EMAIL=admin@example.com
