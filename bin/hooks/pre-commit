#!/usr/bin/env bash
set -e

staged=$(git diff --name-only --cached --diff-filter=ACM | grep '\.rb$' || true)
[ -z "$staged" ] && exit 0

echo "→ RuboCop on staged Ruby files..."

if docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^nice_tasker-web-1$'; then
  docker exec nice_tasker-web-1 bundle exec rubocop \
    --no-color --format simple \
    $(echo "$staged" | sed 's|^|/rails/|')
else
  echo "  (Docker not running — skipping RuboCop)"
fi
