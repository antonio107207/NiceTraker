<div id="checklist_<%= checklist.id %>">
  <% done, total = checklist.progress %>
  <div class="flex items-center justify-between mb-2">
    <h4 class="text-sm font-semibold text-gray-800">☑ <%= checklist.title %></h4>
    <div class="flex items-center gap-2">
      <span id="checklist_counter_<%= checklist.id %>" class="text-xs text-gray-500">
        <%= "#{done}/#{total}" if total > 0 %>
      </span>
      <%= button_to checklist_path(checklist), method: :delete,
            data: { turbo_stream: true, turbo_confirm: t("checklists.delete_confirm") },
            form: { class: "contents" } do %>
        <span class="text-xs text-gray-400 hover:text-red-500 cursor-pointer"><%= t("checklists.delete") %></span>
      <% end %>
    </div>
  </div>

  <div id="checklist_progress_<%= checklist.id %>" class="mb-3">
    <% if total > 0 %>
      <div class="h-1.5 bg-gray-200 rounded-full">
        <div class="h-1.5 rounded-full transition-all duration-300 <%= done == total ? 'bg-green-500' : 'bg-indigo-500' %>"
             style="width: <%= (done.to_f / total * 100).round %>%"></div>
      </div>
    <% end %>
  </div>

  <div id="checklist_items_<%= checklist.id %>">
    <%= render checklist.checklist_items %>
  </div>
  <%= form_with url: checklist_checklist_items_path(checklist), scope: :checklist_item,
        data: { turbo_stream: true, controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
    <%= f.text_field :title, placeholder: t("checklists.add_item_placeholder"),
          class: "w-full text-sm px-3 py-1.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none mt-2" %>
  <% end %>
</div>
