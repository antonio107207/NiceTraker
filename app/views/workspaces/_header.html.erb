<div id="workspace_header" class="flex items-center gap-3 mb-6">
  <div class="w-10 h-10 rounded-lg bg-indigo-600 text-white flex items-center justify-center text-lg font-bold flex-shrink-0">
    <%= workspace.name[0].upcase %>
  </div>
  <div class="flex-1 min-w-0">
    <h1 class="text-xl font-bold text-gray-900 truncate"><%= workspace.name %></h1>
    <% if workspace.description.present? %>
      <p class="text-sm text-gray-500 truncate"><%= workspace.description %></p>
    <% end %>
  </div>
  <div class="flex gap-2 flex-shrink-0">
    <%= link_to t("common.settings"), edit_workspace_path(workspace),
          class: "px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 bg-white text-gray-700 transition-colors",
          data: { turbo_frame: "modal" } %>
    <%= link_to t("workspaces.new_board"), new_workspace_board_path(workspace),
          class: "px-4 py-2 text-sm bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-colors",
          data: { turbo_frame: "modal" } %>
  </div>
</div>
