<% content_for :title, "#{@workspace.name} — NiceTasker" %>

<div class="flex-1 bg-gray-100 min-h-screen">
<div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 sm:py-8">

  <%# Header %>
  <%= render "header", workspace: @workspace %>

  <%# Members management (admin only) %>
  <% if policy(@workspace).remove_member? %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 mb-6">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wider mb-3"><%= t("workspaces.members_title") %></h2>
      <div class="divide-y divide-gray-100">
        <% @workspace.workspace_memberships.includes(:user).each do |membership| %>
          <div id="workspace_member_<%= membership.user.id %>"
               class="flex items-center justify-between py-2.5">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-indigo-400 text-white text-xs flex items-center justify-center font-bold flex-shrink-0">
                <%= membership.user.initials %>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-800"><%= membership.user.display_name %></p>
                <p class="text-xs text-gray-400"><%= membership.user.email %></p>
              </div>
              <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full capitalize"><%= membership.role %></span>
            </div>
            <% unless membership.user == current_user %>
              <%= button_to workspace_membership_path(membership), method: :delete,
                    data: { turbo_stream: true, turbo_confirm: t("boards.remove_member_confirm", name: membership.user.display_name) },
                    form: { class: "contents" },
                    class: "text-sm text-red-500 hover:text-red-700 hover:bg-red-50 px-3 py-1 rounded-lg cursor-pointer transition-colors" do %>
                <%= t("workspaces.remove_member") %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @boards.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      <% @boards.each do |board| %>
        <%= link_to board_path(board),
              class: "group block rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow" do %>
          <div class="h-20 flex items-end p-3"
               style="<%= board_background_style(board) %>">
          </div>
          <div class="bg-white px-4 py-3 border border-t-0 border-gray-200 rounded-b-xl">
            <p class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors truncate">
              <%= board.name %>
            </p>
            <p class="text-xs text-gray-400 mt-0.5 capitalize"><%= board.visibility.humanize %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
      </svg>
      <p class="font-medium"><%= t("workspaces.no_boards") %></p>
      <p class="text-sm mt-1"><%= t("workspaces.no_boards_hint") %></p>
      <%= link_to t("workspaces.create_board"), new_workspace_board_path(@workspace),
            class: "mt-4 inline-block px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm rounded-lg transition-colors",
            data: { turbo_frame: "modal" } %>
    </div>
  <% end %>

  <%# Archived boards %>
  <% if @archived_boards.any? %>
    <details class="mt-6">
      <summary class="flex items-center gap-2 text-sm font-medium text-gray-500 cursor-pointer hover:text-gray-700 select-none list-none">
        <svg class="w-4 h-4 transition-transform details-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <%= t("workspaces.archived_boards", count: @archived_boards.count) %>
      </summary>
      <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
        <% @archived_boards.each do |board| %>
          <div class="group block rounded-xl overflow-hidden shadow-sm opacity-60 hover:opacity-80 transition-opacity">
            <div class="h-16 flex items-end p-3"
                 style="<%= board_background_style(board) %>">
            </div>
            <div class="bg-white px-4 py-3 border border-t-0 border-gray-200 rounded-b-xl flex items-center justify-between gap-2">
              <div class="min-w-0">
                <p class="font-semibold text-gray-700 truncate text-sm"><%= board.name %></p>
                <p class="text-xs text-amber-600 font-medium"><%= t("workspaces.archived_label") %></p>
              </div>
              <% if policy(board).archive? %>
                <%= button_to t("boards.restore_btn"), archive_board_path(board),
                      method: :patch,
                      class: "shrink-0 text-xs px-2 py-1 text-indigo-700 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors cursor-pointer font-medium" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>

</div>
</div>
