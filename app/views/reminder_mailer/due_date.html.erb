<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: ui-sans-serif, system-ui, sans-serif; color: #374151; margin: 0; padding: 0; background: #f9fafb; }
    .container { max-width: 560px; margin: 40px auto; background: white; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.1); overflow: hidden; }
    .header { background: #6366f1; padding: 24px 32px; }
    .header h1 { color: white; margin: 0; font-size: 20px; font-weight: 700; }
    .body { padding: 28px 32px; }
    .greeting { font-size: 15px; color: #374151; margin-bottom: 16px; }
    .card-box { background: #fff7ed; border-left: 3px solid #f59e0b; padding: 12px 16px; border-radius: 6px; margin: 16px 0; }
    .card-title { font-size: 14px; font-weight: 600; color: #1f2937; }
    .due-date { font-size: 13px; color: #b45309; margin-top: 4px; font-weight: 500; }
    .board-name { font-size: 12px; color: #9ca3af; margin-top: 2px; }
    .btn { display: inline-block; background: #6366f1; color: white; text-decoration: none; padding: 10px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; margin-top: 20px; }
    .footer { padding: 14px 32px; background: #f3f4f6; font-size: 12px; color: #9ca3af; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header"><h1>NiceTasker</h1></div>
    <div class="body">
      <p class="greeting"><%= t("reminder_mailer.greeting", name: @user.display_name) %></p>

      <div class="card-box">
        <div class="card-title"><%= @card.title %></div>
        <div class="due-date">📅 <%= t("reminder_mailer.due_on", date: @card.due_date.strftime("%d.%m.%Y")) %></div>
        <div class="board-name"><%= @board.name %></div>
      </div>

      <a class="btn" href="<%= board_card_url(@card.board, @card) %>"><%= t("reminder_mailer.open_card") %></a>
    </div>
    <div class="footer"><%= t("reminder_mailer.footer") %></div>
  </div>
</body>
</html>
