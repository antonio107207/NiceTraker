<%= turbo_frame_tag "card_relation_search_#{@card.id}" do %>
  <% if @results.any? %>
    <div class="mt-2 pt-2 border-t border-gray-100 space-y-1">
      <% @results.each do |result_card| %>
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1.5 flex-1 min-w-0 text-xs">
            <span class="font-mono bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded shrink-0 text-[10px]"><%= result_card.identifier %></span>
            <span class="text-gray-700 truncate"><%= result_card.title %></span>
          </div>
          <%= button_to t("card_relations.link_btn_short"), card_card_relations_path(@card),
                params: { card_relation: { related_card_id: result_card.id, relation_type: @relation_type } },
                data: { turbo_stream: true },
                class: "shrink-0 bg-indigo-600 text-white text-[10px] px-2 py-0.5 rounded hover:bg-indigo-700 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% elsif params[:q].present? %>
    <p class="text-xs text-gray-400 italic mt-2 pt-2 border-t border-gray-100"><%= t("card_relations.not_found") %></p>
  <% end %>
<% end %>
