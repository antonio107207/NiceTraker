<% if card.card_relations.any? %>
  <div>
    <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= t("card_relations.linked_cards") %></h4>
    <div id="card_relations_section_<%= card.id %>">
      <%= render "card_relations/relations_section", card: card %>
    </div>
  </div>
<% else %>
  <div id="card_relations_section_<%= card.id %>"></div>
<% end %>
