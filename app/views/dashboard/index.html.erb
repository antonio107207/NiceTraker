<% content_for :title, t("dashboard.title") %>

<div class="flex-1 bg-gray-100 min-h-screen">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-8">

    <% if @recent_boards.any? %>
      <section class="mb-10">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("dashboard.recently_viewed") %></h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          <%= render @recent_boards %>
        </div>
      </section>
    <% end %>

    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-800"><%= t("dashboard.your_workspaces") %></h2>
        <%= link_to t("dashboard.new_workspace"), new_workspace_path,
              class: "text-sm bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded-lg transition-colors" %>
      </div>

      <% if @workspaces.any? %>
        <% @workspaces.each do |workspace| %>
          <div class="mb-8">
            <div class="flex items-center gap-2 mb-3">
              <%= link_to workspace_path(workspace), class: "w-8 h-8 rounded bg-indigo-600 text-white flex items-center justify-center text-sm font-bold hover:bg-indigo-700 transition-colors" do %>
                <%= workspace.name[0].upcase %>
              <% end %>
              <%= link_to workspace.name, workspace_path(workspace), class: "font-semibold text-gray-800 hover:text-indigo-600 transition-colors" %>
              <%= link_to t("common.settings"), edit_workspace_path(workspace), class: "ml-auto text-xs text-gray-500 hover:text-gray-700" %>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
              <%= render workspace.boards.active.order(:name) %>
              <%= link_to new_workspace_board_path(workspace),
                    class: "group flex items-center justify-center h-24 rounded-xl bg-gray-200 hover:bg-gray-300 transition-colors" do %>
                <span class="text-gray-500 group-hover:text-gray-700 text-sm font-medium"><%= t("dashboard.create_board") %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg mb-2"><%= t("dashboard.no_workspaces") %></p>
          <%= link_to t("dashboard.create_first"), new_workspace_path, class: "text-indigo-600 hover:underline" %>
        </div>
      <% end %>
    </section>
  </div>
</div>
