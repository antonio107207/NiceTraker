<% content_for :title, "#{@workspace.name} — Portal" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <%= link_to portal_workspaces_path, class: "flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <%= t("portal.nav.workspaces") %>
    <% end %>
    <%= button_to portal_workspace_path(@workspace), method: :delete,
          data: { turbo_confirm: t("portal.workspaces.delete_confirm", name: @workspace.name) },
          class: "flex items-center gap-1.5 px-3 py-1.5 text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 transition-colors font-medium cursor-pointer",
          form: { class: "contents" } do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      <%= t("portal.actions.delete") %>
    <% end %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h1 class="text-xl font-bold text-gray-900"><%= @workspace.name %></h1>
    <% if @workspace.description.present? %>
      <p class="text-gray-500 text-sm mt-1"><%= @workspace.description %></p>
    <% end %>
    <div class="flex items-center gap-4 mt-3 text-xs text-gray-400">
      <span><%= t("portal.workspaces.col_owner") %>:
        <%= link_to @workspace.owner.display_name, portal_user_path(@workspace.owner), class: "font-semibold text-indigo-600 hover:text-indigo-800" %>
      </span>
      <span><%= t("portal.workspaces.col_created") %>: <strong class="text-gray-600"><%= @workspace.created_at.strftime("%d %b %Y") %></strong></span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-700"><%= t("portal.nav.boards") %> (<%= @boards.count %>)</h2>
      </div>
      <div class="divide-y divide-gray-50">
        <% if @boards.empty? %>
          <p class="px-5 py-4 text-sm text-gray-400"><%= t("portal.empty") %></p>
        <% else %>
          <% @boards.each do |board| %>
            <%= link_to portal_board_path(board), class: "flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition-colors" do %>
              <div class="w-7 h-7 rounded text-white text-[10px] font-bold flex items-center justify-center shrink-0"
                   style="background: <%= board.background_color.presence || '#4f46e5' %>">
                <%= board.key %>
              </div>
              <span class="text-sm font-medium text-gray-800 flex-1 truncate"><%= board.name %></span>
              <span class="text-xs text-gray-400"><%= board.created_at.strftime("%d.%m.%y") %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-700"><%= t("portal.users.col_user") %> (<%= @members.count %>)</h2>
      </div>
      <div class="divide-y divide-gray-50">
        <% if @members.empty? %>
          <p class="px-5 py-4 text-sm text-gray-400"><%= t("portal.empty") %></p>
        <% else %>
          <% @members.each do |m| %>
            <%= link_to portal_user_path(m.user), class: "flex items-center justify-between px-5 py-3 hover:bg-gray-50 transition-colors" do %>
              <div class="flex items-center gap-2.5">
                <% if m.user.avatar_url.present? %>
                  <img src="<%= m.user.avatar_url %>" class="w-7 h-7 rounded-full object-cover">
                <% else %>
                  <div class="w-7 h-7 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-700"><%= m.user.initials %></div>
                <% end %>
                <span class="text-sm font-medium text-gray-800"><%= m.user.display_name %></span>
              </div>
              <span class="text-xs text-gray-400 capitalize"><%= m.role %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
