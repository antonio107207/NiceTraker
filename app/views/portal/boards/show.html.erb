<% content_for :title, "#{@board.name} — Portal" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <%= link_to portal_boards_path, class: "flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <%= t("portal.nav.boards") %>
    <% end %>
    <div class="flex items-center gap-2">
      <%= link_to board_path(@board), target: "_blank", class: "flex items-center gap-1.5 px-3 py-1.5 text-sm text-indigo-700 bg-indigo-50 border border-indigo-200 rounded-lg hover:bg-indigo-100 transition-colors font-medium" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <%= t("portal.boards.open_board") %>
      <% end %>
      <%= button_to portal_board_path(@board), method: :delete,
            data: { turbo_confirm: t("portal.boards.delete_confirm", name: @board.name) },
            class: "flex items-center gap-1.5 px-3 py-1.5 text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg hover:bg-red-100 transition-colors font-medium cursor-pointer",
            form: { class: "contents" } do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        <%= t("portal.actions.delete") %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-xl text-white text-sm font-bold flex items-center justify-center shrink-0"
           style="background: <%= @board.background_color.presence || '#4f46e5' %>">
        <%= @board.key %>
      </div>
      <div>
        <h1 class="text-xl font-bold text-gray-900"><%= @board.name %></h1>
        <p class="text-sm text-gray-500">
          <%= t("portal.boards.col_workspace") %>:
          <%= link_to @board.workspace.name, portal_workspace_path(@board.workspace), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
        </p>
      </div>
    </div>
    <div class="flex items-center gap-4 mt-4 text-xs text-gray-400">
      <span><%= t("portal.boards.col_members") %>: <strong class="text-gray-600"><%= @members.count %></strong></span>
      <span><%= t("portal.boards.col_lists") %>: <strong class="text-gray-600"><%= @lists.count %></strong></span>
      <span><%= t("portal.boards.col_created") %>: <strong class="text-gray-600"><%= @board.created_at.strftime("%d %b %Y") %></strong></span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-700"><%= t("portal.nav.users") %> (<%= @members.count %>)</h2>
      </div>
      <div class="divide-y divide-gray-50">
        <% if @members.empty? %>
          <p class="px-5 py-4 text-sm text-gray-400"><%= t("portal.empty") %></p>
        <% else %>
          <% @members.each do |m| %>
            <%= link_to portal_user_path(m.user), class: "flex items-center justify-between px-5 py-3 hover:bg-gray-50 transition-colors" do %>
              <div class="flex items-center gap-2.5">
                <% if m.user.avatar_url.present? %>
                  <img src="<%= m.user.avatar_url %>" class="w-7 h-7 rounded-full object-cover">
                <% else %>
                  <div class="w-7 h-7 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-700"><%= m.user.initials %></div>
                <% end %>
                <span class="text-sm font-medium text-gray-800"><%= m.user.display_name %></span>
              </div>
              <span class="text-xs text-gray-400 capitalize"><%= m.role %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-700"><%= t("portal.nav.boards") %> — Lists (<%= @lists.count %>)</h2>
      </div>
      <div class="divide-y divide-gray-50">
        <% if @lists.empty? %>
          <p class="px-5 py-4 text-sm text-gray-400"><%= t("portal.empty") %></p>
        <% else %>
          <% @lists.each do |list| %>
            <div class="flex items-center justify-between px-5 py-3">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-gray-800"><%= list.name %></span>
                <% if list.archived_at.present? %>
                  <span class="text-[10px] text-amber-600 uppercase font-semibold tracking-wide">Archived</span>
                <% end %>
              </div>
              <span class="text-xs text-gray-400"><%= Card.where(list: list).count %> cards</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
