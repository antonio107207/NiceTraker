<% content_for :title, "#{t('portal.nav.users')} — Portal" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= t("portal.nav.users") %></h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= t("portal.users.subtitle", count: @users.count) %></p>
    </div>
  </div>

  <%# Search %>
  <%= form_with url: portal_users_path, method: :get, class: "flex gap-2" do |f| %>
    <div class="relative flex-1 max-w-sm">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <%= f.text_field :q, value: params[:q], placeholder: t("portal.search_placeholder"),
            class: "w-full pl-9 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    </div>
    <%= f.submit t("portal.search_btn"), class: "px-4 py-2 text-sm bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer font-medium" %>
    <% if params[:q].present? %>
      <%= link_to t("portal.clear_search"), portal_users_path, class: "px-4 py-2 text-sm text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors" %>
    <% end %>
  <% end %>

  <%# Table %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-100 bg-gray-50">
          <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("portal.users.col_user") %></th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell"><%= t("portal.users.col_email") %></th>
          <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell"><%= t("portal.users.col_joined") %></th>
          <th class="text-center px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("portal.users.col_role") %></th>
          <th class="text-right px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("portal.col_actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-5 py-3">
              <div class="flex items-center gap-3">
                <% if user.avatar.attached? %>
                  <img src="<%= url_for(user.avatar) %>" class="w-8 h-8 rounded-full object-cover shrink-0">
                <% elsif user.avatar_url.present? %>
                  <img src="<%= user.avatar_url %>" class="w-8 h-8 rounded-full object-cover shrink-0">
                <% else %>
                  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-700 shrink-0">
                    <%= user.initials %>
                  </div>
                <% end %>
                <span class="font-medium text-gray-900"><%= user.display_name %></span>
              </div>
            </td>
            <td class="px-4 py-3 text-gray-500 hidden md:table-cell"><%= user.email %></td>
            <td class="px-4 py-3 text-gray-400 hidden lg:table-cell"><%= user.created_at.strftime("%d %b %Y") %></td>
            <td class="px-4 py-3 text-center">
              <% if user.super_admin? %>
                <span class="inline-flex text-[10px] font-bold uppercase tracking-wider text-violet-700 bg-violet-50 border border-violet-200 px-2 py-0.5 rounded-full">
                  <%= t("portal.users.super_admin_badge") %>
                </span>
              <% else %>
                <span class="inline-flex text-[10px] font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
                  <%= t("portal.users.role_user") %>
                </span>
              <% end %>
            </td>
            <td class="px-5 py-3">
              <div class="flex items-center justify-end gap-2">
                <%= link_to portal_user_path(user),
                      class: "p-1.5 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors",
                      title: t("portal.actions.view") do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <% end %>
                <%= link_to edit_portal_user_path(user),
                      class: "p-1.5 text-gray-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-colors",
                      title: t("portal.actions.edit") do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                <% end %>
                <% unless user == current_user %>
                  <%= button_to toggle_super_admin_portal_user_path(user), method: :patch,
                        class: "p-1.5 rounded-lg transition-colors cursor-pointer #{user.super_admin? ? 'text-violet-500 hover:text-gray-400 hover:bg-gray-50' : 'text-gray-400 hover:text-violet-600 hover:bg-violet-50'}",
                        title: user.super_admin? ? t("portal.users.demote") : t("portal.users.promote"),
                        form: { class: "contents" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  <% end %>
                  <%= button_to portal_user_path(user), method: :delete,
                        data: { turbo_confirm: t("portal.users.delete_confirm", name: user.display_name) },
                        class: "p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors cursor-pointer",
                        title: t("portal.actions.delete"),
                        form: { class: "contents" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
