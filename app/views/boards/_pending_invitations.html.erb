<div id="pending_invitations_section">
  <% if pending_invitations.any? %>
    <div class="px-5 pb-3 border-t border-gray-100 pt-3">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"><%= t("boards.pending_invitations") %></p>
      <% pending_invitations.each do |inv| %>
        <div class="flex items-center justify-between py-1.5">
          <div class="flex items-center gap-3 min-w-0 flex-1">
            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-400 flex-shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-sm text-gray-600 truncate"><%= inv.email %></p>
          </div>
          <span class="text-xs text-amber-600 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full flex-shrink-0 ml-2">
            <%= t("boards.pending") %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
