<%= turbo_stream.replace "flash" do %>
  <div id="flash-notice"
       class="fixed top-4 right-4 z-50 flex items-center gap-2 rounded-lg bg-green-500 px-4 py-3 text-white shadow-lg"
       data-controller="flash"
       data-flash-target="message">
    Invitation sent to <%= params[:email] %>
    <button class="ml-2 text-white/80 hover:text-white" data-action="flash#dismiss">✕</button>
  </div>
<% end %>
