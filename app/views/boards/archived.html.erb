<% content_for :title, "#{@board.name} — #{t('boards.archive_title')}" %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to board_path(@board), class: "text-indigo-600 hover:text-indigo-800 text-sm flex items-center gap-1" do %>
      ← <%= @board.name %>
    <% end %>
    <h1 class="text-xl font-bold text-gray-900"><%= t("boards.archive_title") %></h1>
  </div>

  <% if @archived_lists.empty? && @archived_cards.empty? %>
    <div class="text-center py-16 text-gray-400">
      <p class="text-4xl mb-3">📦</p>
      <p class="text-base"><%= t("boards.archive_empty") %></p>
    </div>
  <% else %>

    <%# Archived lists %>
    <% if @archived_lists.any? %>
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"><%= t("lists.archived_section") %></h2>
      <div class="space-y-2 mb-6" id="archived_lists_list">
        <% @archived_lists.each do |list| %>
          <div id="archived_list_<%= list.id %>"
               class="bg-white rounded-xl shadow-sm border border-gray-100 px-4 py-3 flex items-center justify-between gap-4">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-800 truncate"><%= list.name %></p>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= t("boards.archived_at", time: time_ago_in_words(list.archived_at)) %>
              </p>
            </div>
            <% if policy(list).unarchive? %>
              <%= button_to unarchive_list_path(list), method: :patch,
                    data: { turbo_stream: true },
                    form: { class: "contents" },
                    class: "text-xs bg-indigo-50 text-indigo-700 hover:bg-indigo-100 px-3 py-1.5 rounded-lg font-medium transition-colors cursor-pointer flex-shrink-0" do %>
                <%= t("boards.restore_btn") %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Archived cards %>
    <% if @archived_cards.any? %>
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"><%= t("cards.archived_section") %></h2>
      <div class="space-y-2" id="archived_cards_list">
        <%= render partial: "boards/archived_card", collection: @archived_cards, as: :card %>
      </div>
    <% end %>

  <% end %>
</div>
