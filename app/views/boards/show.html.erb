<% content_for :title, "#{@board.name} — NiceTasker" %>
<%= turbo_stream_from @board %>
<%= turbo_frame_tag "card_modal", src: @open_card ? board_card_path(@open_card.board_id, @open_card) : nil %>

<div class="flex flex-col min-h-[calc(100vh-3.5rem)] sm:h-[calc(100vh-3.5rem)]"
     style="<%= board_background_style(@board) %>"
     data-board-url="<%= board_path(@board) %>">

  <%# Board header %>
  <div class="flex items-center justify-between px-4 py-2 bg-black/20 text-white">
    <div class="flex items-center gap-2 flex-1 min-w-0 mr-2">
      <h1 class="text-base sm:text-xl font-bold truncate"><%= @board.name %></h1>
      <% if @current_membership&.observer? %>
        <span class="hidden sm:inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-white/20 text-white/80 shrink-0">
          <%= t("boards.role_observer") %>
        </span>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <%# Members avatars %>
      <div class="hidden sm:flex -space-x-2">
        <% @board_members.first(5).each do |member| %>
          <div class="w-7 h-7 rounded-full bg-indigo-400 ring-2 ring-white flex items-center justify-center text-xs font-bold text-white"
               title="<%= member.display_name %>">
            <%= member.initials %>
          </div>
        <% end %>
      </div>

      <%# Invite popover — admins only %>
      <% if policy(@board).invite? %>
      <div class="relative" data-controller="dropdown">
        <button data-action="dropdown#toggle"
                class="text-sm bg-white/20 hover:bg-white/30 px-3 py-1.5 rounded-lg font-medium transition-colors flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
          </svg>
          <%= t("boards.invite_btn") %>
        </button>

        <div id="invite_panel"
             data-dropdown-target="menu"
             class="hidden absolute right-0 top-10 w-[22rem] max-w-[calc(100vw-1rem)] bg-white rounded-2xl shadow-2xl z-50 text-gray-800 overflow-hidden">

          <%# Header %>
          <div class="px-5 pt-5 pb-4 border-b border-gray-100">
            <h3 class="font-semibold text-gray-900 mb-4"><%= t("boards.invite_title", name: @board.name) %></h3>
            <%= form_with url: invite_board_path(@board), method: :post,
                  data: { turbo_stream: true } do |f| %>
              <%= f.email_field :email,
                    id: "invite_email_field",
                    placeholder: t("boards.email_placeholder"),
                    required: true,
                    class: "w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none mb-2" %>
              <div class="flex gap-2">
                <%= f.select :role,
                      [[t("boards.role_member"), "member"], [t("boards.role_admin"), "admin"], [t("boards.role_observer"), "observer"]],
                      {},
                      class: "flex-1 px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none bg-white" %>
                <%= f.submit t("boards.send_invite"),
                      class: "flex-1 bg-indigo-600 hover:bg-indigo-700 text-white text-sm py-2 px-3 rounded-lg font-medium transition-colors cursor-pointer" %>
              </div>
            <% end %>
          </div>

          <%# Members list %>
          <div class="max-h-64 overflow-y-auto">
            <%# Current members %>
            <div class="px-5 py-3">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"><%= t("boards.current_members") %></p>
              <% @board.board_memberships.includes(:user).each do |membership| %>
                <div id="board_member_<%= membership.user.id %>"
                     class="flex items-center justify-between py-2 group">
                  <div class="flex items-center gap-3 min-w-0">
                    <% if membership.user.avatar.attached? %>
                      <img src="<%= url_for(membership.user.avatar) %>" alt=""
                           class="w-8 h-8 rounded-full object-cover flex-shrink-0">
                    <% elsif membership.user.avatar_url.present? %>
                      <img src="<%= membership.user.avatar_url %>" alt=""
                           class="w-8 h-8 rounded-full object-cover flex-shrink-0">
                    <% else %>
                      <div class="w-8 h-8 rounded-full bg-indigo-500 text-white text-xs flex items-center justify-center font-bold flex-shrink-0">
                        <%= membership.user.initials %>
                      </div>
                    <% end %>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-gray-800 truncate"><%= membership.user.display_name %></p>
                      <p class="text-xs text-gray-400 truncate"><%= membership.user.email %></p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0 ml-2">
                    <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
                      <%= t("boards.role_#{membership.role}") %>
                    </span>
                    <% if policy(@board).remove_member? && membership.user != current_user %>
                      <%= button_to board_membership_path(membership), method: :delete,
                            data: { turbo_stream: true, turbo_confirm: t("boards.remove_member_confirm", name: membership.user.display_name) },
                            form: { class: "contents" },
                            class: "opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-500 transition-all cursor-pointer text-lg leading-none" do %>×<% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>

            <%# Pending invitations %>
            <%= render "pending_invitations", pending_invitations: @pending_invitations %>
          </div>
        </div>
      </div>
      <% end %>
    </div>
  </div>

  <%# Lists area %>
  <div class="flex-1 sm:overflow-x-auto sm:overflow-y-hidden sm:relative" id="board_lists">

    <%# Lists container — vertical on mobile, horizontal on desktop %>
    <div class="flex flex-col sm:flex-row gap-3 sm:h-full sm:items-start px-3 py-3 sm:pb-16"
         id="lists_container">
      <%= render @lists %>
    </div>

    <%# Add list — only for contributors (not observers) %>
    <% if policy(@board).manage_lists? %>
    <div class="px-3 pb-5 sm:absolute sm:bottom-5 sm:left-4 sm:z-10 sm:px-0 sm:pb-0"
         data-controller="toggle-form" id="add_list_area">
      <div data-toggle-form-target="form" class="hidden w-full sm:w-72 bg-white rounded-xl p-3 shadow-2xl mb-2">
        <%= form_with url: board_lists_path(@board), scope: :list,
              data: { turbo_stream: true, controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
          <%= f.text_field :name, placeholder: t("boards.list_name_placeholder"),
                class: "w-full px-3 py-2 rounded-lg text-sm text-gray-800 border border-gray-200 focus:ring-2 focus:ring-indigo-500 focus:outline-none",
                autofocus: true, required: true %>
          <div class="flex items-center gap-2 mt-2">
            <%= f.submit t("boards.add_list_btn"), class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-3 py-1.5 rounded-lg cursor-pointer" %>
            <button type="button" data-action="toggle-form#hide" class="text-gray-500 hover:text-gray-700 text-sm"><%= t("common.cancel") %></button>
          </div>
        <% end %>
      </div>

      <div data-toggle-form-target="toggle">
        <button data-action="toggle-form#show"
                class="flex items-center gap-1.5 bg-black/20 hover:bg-black/30 backdrop-blur-sm text-white px-3 py-1.5 rounded-full text-sm font-medium transition-colors shadow-sm whitespace-nowrap">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
          </svg>
          <%= t("boards.add_list") %>
        </button>
      </div>
    </div>
    <% end %>

  </div>
</div>
