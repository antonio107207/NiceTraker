<div id="activity_<%= activity.id %>" class="text-xs text-gray-500 py-1 border-b border-gray-50 last:border-0">
  <span class="font-medium text-gray-700"><%= activity.owner.display_name %></span>
  <%= t("activities.#{activity.key}",
        **(activity.parameters&.symbolize_keys || {}),
        default: activity.key.humanize) %>
  <span class="block text-gray-400 mt-0.5">
    <%= t("comments.ago", time: time_ago_in_words(activity.created_at)) %>
  </span>
</div>
