<div id="notification_<%= notification.id %>"
     class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-0 <%= notification.read? ? 'opacity-60' : '' %>">

  <%# Actor avatar %>
  <div class="w-8 h-8 rounded-full bg-indigo-500 text-white text-xs flex items-center justify-center font-bold flex-shrink-0">
    <%= notification.actor.initials %>
  </div>

  <%# Content %>
  <div class="flex-1 min-w-0">
    <p class="text-sm text-gray-800 leading-snug">
      <span class="font-semibold"><%= notification.actor.display_name %></span>
      <%= notification.message %>
    </p>
    <p class="text-xs text-gray-400 mt-0.5"><%= t("notifications.ago", time: time_ago_in_words(notification.created_at)) %></p>
  </div>

  <%# Unread dot + link to card %>
  <div class="flex flex-col items-end gap-1 flex-shrink-0">
    <% unless notification.read? %>
      <%= button_to mark_read_notification_path(notification), method: :patch,
            form: { data: { turbo_stream: true } },
            class: "w-2 h-2 rounded-full bg-indigo-500 hover:bg-indigo-700 transition-colors cursor-pointer",
            title: "Позначити прочитаним" do %><% end %>
    <% end %>
    <%= link_to board_card_path(notification.card.board, notification.card),
          class: "text-[10px] text-indigo-500 hover:text-indigo-700",
          data: { turbo_frame: "card_modal" } do %>
      <%= t("notifications.open") %>
    <% end %>
  </div>
</div>
