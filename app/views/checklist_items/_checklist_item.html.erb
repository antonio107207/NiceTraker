<div id="checklist_item_<%= checklist_item.id %>" class="group flex items-center gap-2 py-1">
  <%= form_with url: checklist_item_path(checklist_item), method: :patch,
        scope: :checklist_item, data: { turbo_stream: true } do |f| %>
    <%= f.check_box :completed, checked: checklist_item.completed?,
          class: "w-4 h-4 text-indigo-600 rounded flex-shrink-0 cursor-pointer",
          onchange: "this.form.requestSubmit()" %>
  <% end %>

  <span class="text-sm flex-1 min-w-0 break-words cursor-text rounded px-0.5 -mx-0.5 hover:bg-gray-100 transition-colors focus:outline-none <%= checklist_item.completed? ? 'line-through text-gray-400' : 'text-gray-700' %>"
        data-controller="editable"
        data-editable-url-value="<%= checklist_item_path(checklist_item) %>"
        data-editable-field-value="checklist_item[title]">
    <%= checklist_item.title %>
  </span>

  <%= button_to checklist_item_path(checklist_item), method: :delete,
        data: { turbo_stream: true, turbo_confirm: t("checklists.delete_item_confirm") },
        form: { class: "contents" },
        class: "flex-shrink-0 w-5 h-5 flex items-center justify-center text-gray-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all cursor-pointer rounded hover:bg-red-50" do %>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  <% end %>
</div>
