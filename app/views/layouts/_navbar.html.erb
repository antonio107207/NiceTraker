<nav class="fixed inset-x-0 top-0 z-30 bg-indigo-700/80 backdrop-blur-md backdrop-saturate-150 text-white border-b border-white/10 shadow-lg shadow-indigo-900/20" data-controller="dropdown">
  <div class="mx-auto max-w-screen-xl flex items-center h-14 px-4 gap-4">

    <%# Logo %>
    <%= link_to "NiceTasker", root_path, class: "text-xl font-bold tracking-tight shrink-0 mr-2" %>

    <%# Desktop nav links %>
    <div class="hidden sm:flex items-center gap-1 flex-1">
      <%= link_to t("nav.boards"),  root_path,    class: "text-sm px-3 py-1.5 rounded-lg hover:bg-white/15 transition-colors font-medium" %>
      <%= link_to t("nav.reports"), reports_path, class: "text-sm px-3 py-1.5 rounded-lg hover:bg-white/15 transition-colors font-medium" %>
    </div>

    <%# Right-side controls %>
    <div class="flex items-center gap-1.5 sm:gap-2 ml-auto">

      <%# Theme cycle button %>
      <button data-action="click->theme#cycle"
              class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/20 transition-colors text-white/90">
        <span data-theme-target="icon" class="flex items-center justify-center">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </span>
      </button>

      <%# Divider %>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>

      <%# Language switcher %>
      <div class="flex items-center gap-0.5 bg-white/10 rounded-lg p-0.5">
        <%= button_to "EN", switch_locale_path, params: { locale: :en }, method: :post,
              form: { class: "contents" },
              class: "text-xs px-2 py-1 rounded-md font-medium transition-colors cursor-pointer #{I18n.locale == :en ? 'bg-white text-indigo-700' : 'text-white/70 hover:text-white'}" %>
        <%= button_to "UA", switch_locale_path, params: { locale: :uk }, method: :post,
              form: { class: "contents" },
              class: "text-xs px-2 py-1 rounded-md font-medium transition-colors cursor-pointer #{I18n.locale == :uk ? 'bg-white text-indigo-700' : 'text-white/70 hover:text-white'}" %>
      </div>

      <%# Divider %>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>

      <%# Notification bell %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle"
                class="relative w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/20 transition-colors text-white/90">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span id="notification_badge">
            <% unread_count = current_user.notifications.unread.count %>
            <% if unread_count > 0 %>
              <span class="absolute -top-0.5 -right-0.5 min-w-[16px] h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center px-0.5 pointer-events-none">
                <%= unread_count > 9 ? "9+" : unread_count %>
              </span>
            <% end %>
          </span>
        </button>

        <div data-dropdown-target="menu"
             class="hidden absolute right-0 top-11 w-80 glass-panel bg-white/85 backdrop-blur-xl backdrop-saturate-150 rounded-xl shadow-xl shadow-gray-900/10 z-50 overflow-hidden">
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
            <h3 class="text-sm font-semibold text-gray-800"><%= t("notifications.title") %></h3>
            <%= button_to t("notifications.mark_all_read"), mark_all_read_notifications_path, method: :patch,
                  form: { data: { turbo_stream: true } },
                  class: "text-xs text-indigo-600 hover:text-indigo-800 transition-colors cursor-pointer" %>
          </div>
          <div id="notifications_list" class="max-h-96 overflow-y-auto">
            <%= render "notifications/list",
                  notifications: current_user.notifications.unread.recent.includes(:actor, :notifiable) %>
          </div>
        </div>
      </div>

      <%# Divider %>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>

      <%# User dropdown %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle"
                class="flex items-center gap-2 px-2 py-1 rounded-lg hover:bg-white/15 transition-colors">
          <% if current_user.avatar.attached? %>
            <img src="<%= url_for(current_user.avatar) %>" alt=""
                 class="w-7 h-7 rounded-full object-cover">
          <% elsif current_user.avatar_url.present? %>
            <img src="<%= current_user.avatar_url %>" alt=""
                 class="w-7 h-7 rounded-full object-cover">
          <% else %>
            <div class="w-7 h-7 rounded-full bg-indigo-500 ring-2 ring-white/30 flex items-center justify-center text-xs font-semibold">
              <%= current_user.initials %>
            </div>
          <% end %>
          <span class="hidden sm:inline text-sm font-medium truncate max-w-[7rem]"><%= current_user.display_name %></span>
          <svg class="hidden sm:block w-3.5 h-3.5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <div data-dropdown-target="menu"
             class="hidden absolute right-0 top-11 w-48 glass-panel bg-white/85 backdrop-blur-xl backdrop-saturate-150 rounded-xl shadow-xl shadow-gray-900/10 py-1 z-50 text-gray-700">
          <%= link_to t("nav.profile"), edit_user_registration_path,
                class: "flex items-center gap-2.5 px-4 py-2.5 text-sm hover:bg-gray-50 transition-colors" %>
          <div class="border-t border-gray-100 my-1"></div>
          <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
                form: { class: "contents" },
                class: "flex items-center gap-2.5 w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition-colors cursor-pointer" %>
        </div>
      </div>

      <%# Hamburger — mobile only %>
      <button class="sm:hidden flex items-center justify-center w-8 h-8 rounded-lg hover:bg-white/20 transition-colors"
              data-action="click->dropdown#toggle"
              aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <%# Mobile nav panel %>
  <div data-dropdown-target="menu" class="hidden sm:hidden border-t border-indigo-600 bg-indigo-800">
    <div class="px-4 py-3 space-y-1">
      <%= link_to t("nav.boards"),  root_path,    class: "block py-2.5 text-sm text-white hover:text-indigo-200 transition-colors" %>
      <%= link_to t("nav.reports"), reports_path, class: "block py-2.5 text-sm text-white hover:text-indigo-200 transition-colors" %>
    </div>
  </div>
</nav>
