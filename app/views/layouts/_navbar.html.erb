<nav class="bg-indigo-700 text-white shadow-md" data-controller="dropdown">
  <div class="mx-auto max-w-screen-xl flex items-center justify-between h-14 px-4">
    <%= link_to "NiceTasker", root_path, class: "text-xl font-bold tracking-tight shrink-0" %>

    <%# Desktop nav links — hidden on mobile %>
    <div class="hidden sm:flex items-center gap-4">
      <%= link_to t("nav.boards"),  root_path,    class: "text-sm hover:text-indigo-200 transition-colors" %>
      <%= link_to t("nav.reports"), reports_path, class: "text-sm hover:text-indigo-200 transition-colors" %>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <%# Theme toggle %>
      <button data-action="click->theme#cycle"
              title="Toggle theme"
              class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/20 transition-colors text-base leading-none">
        <span data-theme-target="icon">🖥</span>
      </button>

      <%# Language switcher %>
      <div class="flex items-center gap-0.5 bg-white/10 rounded-lg p-0.5">
        <%= button_to "EN", switch_locale_path, params: { locale: :en }, method: :post,
              form: { class: "contents" },
              class: "text-xs px-2 py-1 rounded-md font-medium transition-colors cursor-pointer #{I18n.locale == :en ? 'bg-white text-indigo-700' : 'text-white/70 hover:text-white'}" %>
        <%= button_to "UA", switch_locale_path, params: { locale: :uk }, method: :post,
              form: { class: "contents" },
              class: "text-xs px-2 py-1 rounded-md font-medium transition-colors cursor-pointer #{I18n.locale == :uk ? 'bg-white text-indigo-700' : 'text-white/70 hover:text-white'}" %>
      </div>

      <%# User dropdown %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="flex items-center gap-2 text-sm hover:text-indigo-200">
          <% if current_user.avatar_url.present? %>
            <img src="<%= current_user.avatar_url %>" alt="<%= current_user.display_name %>"
                 class="w-8 h-8 rounded-full object-cover">
          <% else %>
            <div class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-xs font-medium">
              <%= current_user.initials %>
            </div>
          <% end %>
          <span class="hidden sm:inline truncate max-w-[8rem]"><%= current_user.display_name %></span>
        </button>

        <div data-dropdown-target="menu"
             class="hidden absolute right-0 top-10 w-48 bg-white rounded-lg shadow-lg py-1 z-50 text-gray-700">
          <%= link_to t("nav.profile"), edit_user_registration_path,
                class: "block px-4 py-2 text-sm hover:bg-gray-100" %>
          <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
                class: "block w-full text-left px-4 py-2 text-sm hover:bg-gray-100" %>
        </div>
      </div>

      <%# Hamburger — mobile only %>
      <button class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg hover:bg-white/20 transition-colors"
              data-action="click->dropdown#toggle"
              aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <%# Mobile nav panel %>
  <div data-dropdown-target="menu" class="hidden sm:hidden border-t border-indigo-600 bg-indigo-800">
    <div class="px-4 py-3 space-y-1">
      <%= link_to t("nav.boards"),  root_path,    class: "block py-2.5 text-sm text-white hover:text-indigo-200 transition-colors" %>
      <%= link_to t("nav.reports"), reports_path, class: "block py-2.5 text-sm text-white hover:text-indigo-200 transition-colors" %>
    </div>
  </div>
</nav>
