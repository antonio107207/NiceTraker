<div id="comment_<%= comment.id %>" class="flex gap-3 mb-4 group" data-controller="inline-edit">
  <div class="w-8 h-8 rounded-full bg-indigo-400 text-white text-xs flex items-center justify-center font-medium flex-shrink-0 mt-0.5">
    <%= comment.user.initials %>
  </div>

  <div class="flex-1 min-w-0">

    <%# View mode %>
    <div data-inline-edit-target="view">
      <div class="flex items-baseline gap-2 mb-1">
        <span class="text-sm font-semibold text-gray-800"><%= comment.user.display_name %></span>
        <span class="text-xs text-gray-400"><%= t("comments.ago", time: time_ago_in_words(comment.created_at)) %></span>
        <% if comment.updated_at > comment.created_at + 5.seconds %>
          <span class="text-xs text-gray-300 italic"><%= t("comments.edited") %></span>
        <% end %>
        <% if comment.user_id == current_user.id %>
          <div class="ml-auto flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <button type="button" data-action="click->inline-edit#edit"
                    class="text-xs text-gray-400 hover:text-indigo-500 transition-colors">
              <%= t("common.edit") %>
            </button>
            <%= button_to comment_path(comment), method: :delete,
                  data: { turbo_stream: true, turbo_confirm: t("comments.delete_confirm") },
                  class: "text-xs text-gray-400 hover:text-red-500 transition-colors bg-transparent border-0 cursor-pointer p-0" do %>
              <%= t("common.delete") %>
            <% end %>
          </div>
        <% end %>
      </div>
      <p class="text-sm text-gray-700 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 whitespace-pre-wrap"><%= comment.body %></p>
    </div>

    <%# Edit mode (own comments only) %>
    <% if comment.user_id == current_user.id %>
      <div data-inline-edit-target="form" class="hidden">
        <%= form_with model: comment, data: { turbo_stream: true } do |f| %>
          <%= f.text_area :body, rows: 3,
                class: "w-full px-3 py-2 text-sm border border-indigo-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none resize-none" %>
          <div class="flex items-center gap-2 mt-1.5">
            <%= f.submit t("common.save"),
                  class: "bg-indigo-600 text-white text-sm px-3 py-1 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
            <button type="button" data-action="click->inline-edit#cancel"
                    class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
              <%= t("common.cancel") %>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
