<%= turbo_stream.append "cards_list_#{@list.id}" do %>
  <%= render @card %>
<% end %>
<%= turbo_stream.replace "new_card_form_#{@list.id}" do %>
  <div id="new_card_form_<%= @list.id %>" data-toggle-form-target="form" class="hidden">
    <%= form_with url: list_cards_path(@list), scope: :card, data: { turbo_stream: true } do |f| %>
      <%= f.text_area :title, placeholder: "Enter a title for this card…",
            rows: 3,
            class: "w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none resize-none",
            autofocus: true, required: true %>
      <div class="flex items-center gap-2 mt-1">
        <%= f.submit "Add card", class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-3 py-1.5 rounded-lg cursor-pointer" %>
        <button type="button" data-action="toggle-form#hide" class="text-gray-500 hover:text-gray-700 text-sm">✕</button>
      </div>
    <% end %>
  </div>
<% end %>
