<%= turbo_frame_tag "card_modal" do %>
  <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 flex items-start justify-center pt-0 sm:pt-10 px-0 sm:px-4 pb-0 sm:pb-4"
       data-controller="modal"
       data-action="keydown.esc@window->modal#close">

    <div class="bg-white/95 backdrop-blur-2xl sm:rounded-2xl shadow-2xl shadow-gray-900/20 w-full max-w-2xl h-full sm:max-h-[90vh] flex flex-col overflow-hidden"
         data-modal-target="dialog">

      <%# Cover (outside scroll, part of sticky header area) %>
      <% if @card.cover_color.present? %>
        <div class="h-24 rounded-t-2xl flex-shrink-0" style="background-color: <%= @card.cover_color %>"></div>
      <% end %>

      <%# Sticky header %>
      <div class="flex-shrink-0 px-4 sm:px-6 pt-4 sm:pt-5 pb-4 border-b border-gray-100/60 bg-white/80 backdrop-blur-sm">
        <div class="flex items-start justify-between gap-4">
          <h2 class="text-xl font-bold text-gray-900 flex-1 leading-snug"
              data-controller="editable"
              data-editable-url-value="<%= card_path(@card) %>"
              data-editable-field-value="card[title]">
            <%= @card.title %>
          </h2>
          <button type="button" data-action="click->modal#close"
                  class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors text-lg leading-none">
            ✕
          </button>
        </div>

        <% if @card.number.present? %>
          <div class="flex items-center gap-2 mt-2"
               data-controller="clipboard"
               data-clipboard-text-value="<%= "feature/#{@card.identifier}-#{@card.title.downcase.gsub(/[^a-z0-9]+/, '-').gsub(/^-|-$/, '')}" %>">
            <span class="text-xs font-mono bg-gray-100 text-gray-600 px-2 py-0.5 rounded font-medium"><%= @card.identifier %></span>
            <button type="button" data-action="click->clipboard#copy"
                    class="text-xs text-indigo-500 hover:text-indigo-700 flex items-center gap-1 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <span data-clipboard-target="label"><%= t("cards.copy_branch") %></span>
            </button>
          </div>
        <% end %>

        <p id="card_in_list_<%= @card.id %>" class="text-xs text-gray-400 mt-1"><%= t("cards.in_list", name: @card.list.name) %></p>
      </div>

      <%# Scrollable body %>
      <div class="flex-1 overflow-y-auto modal-scroll px-4 sm:px-6 py-4 sm:py-5">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">

          <%# Main content — full width on mobile, 2/3 on desktop %>
          <div class="sm:col-span-2 space-y-5 sm:space-y-6">

            <%# Due date %>
            <div id="card_due_date_<%= @card.id %>">
              <% if @card.due_date.present? %>
                <div>
                  <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1"><%= t("cards.due_date") %></h4>
                  <span class="text-sm <%= @card.due_date < Time.current && !@card.due_completed ? 'text-red-600 font-medium' : 'text-gray-700' %>">
                    <%= @card.due_date.strftime("%B %d, %Y") %>
                  </span>
                </div>
              <% end %>
            </div>

            <%# Description %>
            <div>
              <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= t("cards.description") %></h4>
              <%= form_with model: @card, data: { turbo_stream: true, controller: "description-form" } do |f| %>
                <%= f.rich_text_area :description %>
                <div class="flex items-center gap-2 mt-2">
                  <%= f.submit t("common.save"),
                        class: "bg-indigo-600 text-white text-sm px-3 py-1.5 rounded-lg hover:bg-indigo-700 cursor-pointer",
                        data: { description_form_target: "submit" } %>
                  <span class="text-xs text-gray-400 hidden" data-description-form-target="saved"><%= t("common.saved") %></span>
                </div>
              <% end %>
            </div>

            <%# Attachments %>
            <%= render "cards/attachments_section", card: @card %>

            <%# Checklists %>
            <div id="card_<%= @card.id %>_checklists">
              <% @checklists.each do |checklist| %>
                <div id="checklist_<%= checklist.id %>">
                  <%= render "checklists/checklist", checklist: checklist %>
                </div>
              <% end %>
            </div>

            <%# Linked cards %>
            <div id="card_relations_<%= @card.id %>">
              <%= render "card_relations/linked_cards", card: @card %>
            </div>

            <%# Time tracking %>
            <div id="card_time_tracking_<%= @card.id %>">
              <%= render "cards/time_tracking_section", card: @card %>
            </div>

            <%# Comments %>
            <div>
              <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("cards.activity") %></h4>
              <div id="card_comments_<%= @card.id %>">
                <%= render @comments %>
              </div>
              <% if policy(@board).create_comment? %>
                <%= form_with url: card_comments_path(@card), scope: :comment,
                      data: { turbo_stream: true, controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
                  <div class="flex gap-3 mt-3">
                    <div class="w-8 h-8 rounded-full bg-indigo-400 text-white text-xs flex items-center justify-center font-medium flex-shrink-0">
                      <%= current_user.initials %>
                    </div>
                    <div class="flex-1 relative"
                         data-controller="mention"
                         data-mention-members-value="<%= @board_members.map(&:display_name).to_json %>">
                      <%= f.text_area :body, placeholder: t("cards.comment_placeholder"), rows: 2,
                            class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:outline-none resize-none",
                            data: { mention_target: "input",
                                    action: "input->mention#onInput keydown->mention#onKeydown" } %>
                      <div data-mention-target="dropdown"
                           class="hidden absolute left-0 right-0 bottom-full mb-1 bg-white/90 backdrop-blur-xl border border-white/60 rounded-lg shadow-lg shadow-gray-900/10 z-50 max-h-40 overflow-y-auto">
                        <div data-mention-target="list"></div>
                      </div>
                      <%= f.submit t("common.save"), class: "mt-1 bg-indigo-600 text-white text-sm px-3 py-1 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>

          <%# Sidebar — right 1/3 %>
          <div class="space-y-1">
            <% _board_policy = policy(@board) %>
            <% if _board_policy.manage_cards? %>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= t("cards.add_to_card") %></p>

            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("cards.labels_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-2 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <%= render "cards/labels_panel", card: @card, labels: @labels %>
              </div>
            </div>

            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("cards.members_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-2 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <%= render "cards/members_panel", card: @card, board_members: @board_members %>
              </div>
            </div>

            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("cards.dates_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-3 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <p class="text-xs text-gray-500 font-medium mb-2"><%= t("cards.due_date") %></p>
                <%= form_with url: card_path(@card), method: :patch, scope: :card, data: { turbo_stream: true } do |f| %>
                  <%= f.date_field :due_date, value: @card.due_date&.to_date,
                        class: "w-full px-2 py-1.5 text-sm border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 mb-2" %>
                  <div class="flex gap-2">
                    <%= f.submit t("cards.save_date"), class: "flex-1 bg-indigo-600 text-white text-xs py-1.5 rounded hover:bg-indigo-700 cursor-pointer" %>
                    <% if @card.due_date.present? %>
                      <%= button_to card_path(@card), method: :patch,
                            params: { card: { due_date: "" } },
                            data: { turbo_stream: true },
                            class: "flex-1 text-xs bg-gray-100 text-gray-600 py-1.5 rounded hover:bg-gray-200 cursor-pointer" do %><%= t("cards.clear_date") %><% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>

            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("cards.attachment_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-3 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <p class="text-xs text-gray-500 font-medium mb-2"><%= t("cards.attach_file") %></p>
                <%= form_with url: card_attachments_path(@card), data: { turbo_stream: true } do |f| %>
                  <%= f.file_field :attachments, multiple: true,
                        class: "w-full text-xs text-gray-600 mb-2 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer" %>
                  <%= f.submit t("common.upload"), class: "w-full bg-indigo-600 text-white text-xs py-1.5 rounded hover:bg-indigo-700 cursor-pointer" %>
                <% end %>
              </div>
            </div>

            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("cards.checklist_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-3 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <p class="text-xs text-gray-500 font-medium mb-2"><%= t("cards.add_checklist") %></p>
                <%= form_with url: card_checklists_path(@card), scope: :checklist,
                      data: { turbo_stream: true, controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
                  <%= f.text_field :title, placeholder: t("cards.checklist_title_placeholder"),
                        class: "w-full px-2 py-1.5 text-sm border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 mb-2",
                        autofocus: true %>
                  <%= f.submit t("common.add"), class: "w-full bg-indigo-600 text-white text-xs py-1.5 rounded hover:bg-indigo-700 cursor-pointer" %>
                <% end %>
              </div>
            </div>

            <%# Link card dropdown %>
            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("card_relations.sidebar_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-2 p-2 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <%= form_with url: search_card_card_relations_path(@card), method: :get,
                      class: "space-y-3",
                      data: { turbo_frame: "card_relation_search_#{@card.id}" } do |f| %>

                  <%= f.select :relation_type,
                        CardRelation::TYPES.map { |type| [t("card_relations.select_#{type}"), type] },
                        { selected: "relates_to" },
                        class: "w-full px-2 py-1.5 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 bg-white" %>

                  <div class="flex gap-1 min-w-0">
                    <%= f.text_field :q,
                          placeholder: "BOARD-4 або назва…",
                          autocomplete: "off",
                          class: "min-w-0 flex-1 px-2 py-1.5 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
                    <%= f.submit "Знайти", class: "shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-xs px-2 py-1 rounded cursor-pointer" %>
                  </div>

                <% end %>

                <%= turbo_frame_tag "card_relation_search_#{@card.id}" %>
              </div>
            </div>

            <%# Time tracking dropdown %>
            <div data-controller="dropdown timer"
                 data-timer-card-id-value="<%= @card.id %>">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("time_tracking.sidebar_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-3 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10 space-y-4">

                <%# Estimate %>
                <div>
                  <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-1.5"><%= t("time_tracking.estimate") %></p>
                  <%= form_with url: card_time_entries_path(@card), scope: :time_entry, data: { turbo_stream: true } do |f| %>
                    <%= f.hidden_field :duration, value: "" %>
                    <%= f.text_field :estimate,
                          value: @card.formatted_time(@card.estimated_minutes),
                          placeholder: "2h, 30m, 1.5h…",
                          autocomplete: "off",
                          class: "w-full px-2 py-1.5 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 mb-1.5" %>
                    <%= f.submit t("time_tracking.save_estimate"), class: "w-full bg-indigo-600 text-white text-xs py-1.5 rounded hover:bg-indigo-700 cursor-pointer" %>
                  <% end %>
                </div>

                <%# Live timer %>
                <div>
                  <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-1.5"><%= t("time_tracking.timer") %></p>
                  <div class="flex items-center gap-2">
                    <button data-action="click->timer#start" data-timer-target="startBtn"
                            class="flex-1 bg-green-100 text-green-700 hover:bg-green-200 text-xs px-2 py-1.5 rounded transition-colors text-center">
                      ▶ <%= t("time_tracking.start_timer") %>
                    </button>
                    <button data-action="click->timer#stop" data-timer-target="stopBtn"
                            class="hidden flex-1 bg-red-100 text-red-700 hover:bg-red-200 text-xs px-2 py-1.5 rounded transition-colors text-center">
                      ■ <%= t("time_tracking.stop_timer") %>
                    </button>
                    <span data-timer-target="display" class="text-xs font-mono text-indigo-600 font-medium w-12 text-right"></span>
                  </div>
                </div>

                <%# Log time %>
                <div>
                  <p class="text-xs text-gray-500 font-semibold uppercase tracking-wide mb-1.5"><%= t("time_tracking.log_time") %></p>
                  <%= form_with url: card_time_entries_path(@card), scope: :time_entry,
                        data: { turbo_stream: true, controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
                    <%= f.text_field :duration,
                          data: { timer_target: "durationInput" },
                          placeholder: "2h, 30m, 1.5h…",
                          autocomplete: "off",
                          class: "w-full px-2 py-1.5 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 mb-1.5" %>
                    <%= f.text_field :description,
                          placeholder: t("time_tracking.description_placeholder"),
                          autocomplete: "off",
                          class: "w-full px-2 py-1.5 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 mb-1.5" %>
                    <%= f.submit t("time_tracking.log_btn"), class: "w-full bg-indigo-600 text-white text-xs py-1.5 rounded hover:bg-indigo-700 cursor-pointer" %>
                  <% end %>
                </div>
              </div>
            </div>

            <% end %><%# end manage_cards? %>

            <% if _board_policy.manage_cards? %>
            <hr class="my-3">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2"><%= t("cards.actions") %></p>

            <%# Move to list %>
            <div data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="w-full text-left bg-gray-100 hover:bg-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 transition-colors">
                <%= t("cards.move_btn") %>
              </button>
              <div data-dropdown-target="menu" class="hidden mt-1 p-3 bg-white/85 backdrop-blur-xl rounded-lg border border-white/60 shadow-lg shadow-gray-900/10">
                <p class="text-xs text-gray-500 font-medium mb-2"><%= t("cards.move_to_list") %></p>
                <%= form_with model: @card, data: { turbo_stream: true } do |f| %>
                  <%= f.select :list_id,
                        @board_lists.map { |l| [l.name, l.id] },
                        { selected: @card.list_id },
                        class: "w-full px-2 py-1.5 text-sm border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-indigo-500 bg-white mb-2" %>
                  <%= f.submit t("cards.move_confirm"), class: "w-full bg-indigo-600 text-white text-xs py-1.5 rounded hover:bg-indigo-700 cursor-pointer" %>
                <% end %>
              </div>
            </div>

            <%= button_to card_path(@card), method: :delete,
                  data: { turbo_stream: true, turbo_confirm: t("cards.archive_confirm") },
                  class: "w-full text-left bg-gray-100 hover:bg-red-100 hover:text-red-700 rounded-lg px-3 py-2 text-sm text-gray-700 cursor-pointer transition-colors mt-1" do %>
              <%= t("cards.archive_btn") %>
            <% end %>
            <% end %><%# end manage_cards? (actions) %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
