<%= turbo_stream.prepend "flash_messages" do %>
  <div class="fixed top-4 left-4 right-4 sm:left-auto sm:right-4 sm:max-w-sm z-50 flex items-center gap-2 rounded-lg backdrop-blur-md bg-red-500/90 shadow-red-900/20 px-4 py-3 text-white shadow-lg"
       data-controller="flash">
    <%= @flash_message %>
    <button class="ml-auto text-white/80 hover:text-white" data-action="flash#dismiss">✕</button>
  </div>
<% end %>
