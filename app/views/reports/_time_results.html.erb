<%# Summary strip %>
<div class="grid grid-cols-2 gap-3 sm:gap-4 mb-4">
  <%= render "reports/stat_card", label: t("reports.time.total_logged"), value: fmt_minutes(@total_minutes), color: "indigo" %>
  <%= render "reports/stat_card", label: t("reports.time.entries"),      value: @results.size,              color: "gray" %>
</div>

<%# Per-user summary %>
<% if @by_user.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-4">
    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3"><%= t("reports.time.by_user") %></h3>
    <div class="flex flex-wrap gap-3">
      <% @by_user.each do |user, minutes| %>
        <div class="flex items-center gap-2 bg-gray-50 rounded-lg px-3 py-2">
          <div class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-700 text-xs flex items-center justify-center font-medium">
            <%= user.initials %>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-800"><%= user.display_name %></p>
            <p class="text-xs text-indigo-600 font-semibold"><%= fmt_minutes(minutes) %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Entries table %>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-5 py-3 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700"><%= t("reports.types.time") %> &mdash; <%= @results.size %> <%= t("reports.items") %></h2>
  </div>

  <% if @results.empty? %>
    <p class="px-5 py-10 text-sm text-gray-400 text-center"><%= t("reports.no_data") %></p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.time.date") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.time.user") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.time.card") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.time.board") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.time.duration") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.time.note") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @results.each do |entry| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 whitespace-nowrap text-xs text-gray-500"><%= entry.logged_at.strftime("%d %b %Y") %></td>
              <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs flex items-center justify-center font-medium shrink-0">
                    <%= entry.user.initials %>
                  </div>
                  <span class="text-gray-700 text-xs"><%= entry.user.display_name %></span>
                </div>
              </td>
              <td class="px-4 py-3 whitespace-nowrap">
                <span class="font-mono text-xs bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded"><%= entry.card.identifier %></span>
                <span class="text-xs text-gray-700 ml-1 truncate"><%= entry.card.title.truncate(30) %></span>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-xs text-gray-500"><%= entry.card.board.name %></td>
              <td class="px-4 py-3 whitespace-nowrap">
                <span class="text-xs font-semibold text-indigo-600"><%= entry.formatted %></span>
              </td>
              <td class="px-4 py-3 text-xs text-gray-500 max-w-xs truncate"><%= entry.description.presence || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
