<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-5 py-3 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700"><%= t("reports.types.boards") %> &mdash; <%= @results.size %> <%= t("reports.boards.boards_cnt") %></h2>
  </div>

  <% if @results.empty? %>
    <p class="px-5 py-10 text-sm text-gray-400 text-center"><%= t("reports.no_data") %></p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.board") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.members") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.total") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.active") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.overdue") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.done") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.time_logged") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.boards.completion") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @results.each do |row| %>
            <%
              board = row[:board]
              done_pct = row[:total] > 0 ? (row[:done].to_f / row[:total] * 100).round : 0
            %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-2">
                  <% if board.background_color.present? %>
                    <div class="w-3 h-3 rounded-sm shrink-0" style="background-color: <%= board.background_color %>"></div>
                  <% end %>
                  <%= link_to board_path(board), class: "font-medium text-indigo-600 hover:text-indigo-800" do %>
                    <%= board.name %>
                  <% end %>
                  <span class="text-xs font-mono text-gray-400"><%= board.key %></span>
                </div>
              </td>
              <td class="px-4 py-3 text-right text-gray-600"><%= row[:members] %></td>
              <td class="px-4 py-3 text-right font-medium text-gray-700"><%= row[:total] %></td>
              <td class="px-4 py-3 text-right text-blue-600"><%= row[:active] %></td>
              <td class="px-4 py-3 text-right <%= row[:overdue] > 0 ? 'text-red-600 font-medium' : 'text-gray-400' %>">
                <%= row[:overdue] %>
              </td>
              <td class="px-4 py-3 text-right text-green-600"><%= row[:done] %></td>
              <td class="px-4 py-3 text-right font-semibold text-indigo-600"><%= fmt_minutes(row[:time_minutes]) %></td>
              <td class="px-4 py-3 min-w-[140px]">
                <div class="flex items-center gap-2">
                  <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-green-500 rounded-full" style="width: <%= done_pct %>%"></div>
                  </div>
                  <span class="text-xs text-gray-500 w-8 text-right"><%= done_pct %>%</span>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
