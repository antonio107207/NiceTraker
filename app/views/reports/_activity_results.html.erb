<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-5 py-3 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700"><%= t("reports.types.activity") %> &mdash; <%= @results.size %> <%= t("reports.activity.devs") %></h2>
  </div>

  <% if @results.empty? %>
    <p class="px-5 py-10 text-sm text-gray-400 text-center"><%= t("reports.no_data") %></p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.activity.developer") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.activity.cards_assigned") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.activity.cards_done") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.activity.time_logged") %></th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.activity.comments") %></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= t("reports.activity.progress") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% max_time = (@results.map { |r| r[:time_minutes] }.max || 1).to_f %>
          <% @results.each do |row| %>
            <%
              user = row[:user]
              pct  = max_time > 0 ? (row[:time_minutes] / max_time * 100).round : 0
              done_pct = row[:cards_assigned] > 0 ? (row[:cards_done].to_f / row[:cards_assigned] * 100).round : 0
            %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <% if user.avatar_url.present? %>
                    <img src="<%= user.avatar_url %>" class="w-8 h-8 rounded-full object-cover" alt="">
                  <% else %>
                    <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 text-sm flex items-center justify-center font-medium">
                      <%= user.initials %>
                    </div>
                  <% end %>
                  <div>
                    <p class="font-medium text-gray-900 text-sm"><%= user.display_name %></p>
                    <p class="text-xs text-gray-400"><%= user.email %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-right font-medium text-gray-700"><%= row[:cards_assigned] %></td>
              <td class="px-4 py-3 text-right">
                <span class="font-medium text-green-600"><%= row[:cards_done] %></span>
                <span class="text-xs text-gray-400 ml-1">(<%= done_pct %>%)</span>
              </td>
              <td class="px-4 py-3 text-right font-semibold text-indigo-600"><%= fmt_minutes(row[:time_minutes]) %></td>
              <td class="px-4 py-3 text-right text-gray-600"><%= row[:comments] %></td>
              <td class="px-4 py-3 min-w-[120px]">
                <div class="h-1.5 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full bg-indigo-500 rounded-full" style="width: <%= pct %>%"></div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
