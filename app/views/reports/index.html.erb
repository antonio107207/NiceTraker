<% content_for :title, t("reports.title") %>

<div class="mx-auto max-w-screen-xl px-4 py-6 sm:py-8">

  <%# Header %>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-6">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900"><%= t("reports.title") %></h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= t("reports.subtitle") %></p>
    </div>
    <% if @results %>
      <%= link_to export_reports_path(params.to_unsafe_h.except("_method", "authenticity_token").merge(format: :csv)),
            class: "self-start flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm px-4 py-2 rounded-lg transition-colors whitespace-nowrap" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <%= t("reports.export_csv") %>
      <% end %>
    <% end %>
  </div>

  <%# Filter form %>
  <%= form_with url: reports_path, method: :get, class: "bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-6" do |f| %>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3 sm:gap-4 mb-4">

      <%# Report type %>
      <div class="sm:col-span-1 lg:col-span-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= t("reports.filters.report_type") %></label>
        <%= f.select :report_type,
              [["📋 #{t("reports.types.cards")}", "cards"],
               ["⏱ #{t("reports.types.time")}", "time"],
               ["👤 #{t("reports.types.activity")}", "activity"],
               ["📊 #{t("reports.types.boards")}", "boards"]],
              { selected: @report_type },
              class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
      </div>

      <%# Board %>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= t("reports.filters.board") %></label>
        <%= f.select :board_id,
              [[t("reports.filters.all_boards"), ""]] + @boards.map { |b| [b.name, b.id] },
              { selected: @board_id },
              class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
      </div>

      <%# User %>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= t("reports.filters.user") %></label>
        <%= f.select :user_id,
              [[t("reports.filters.all_users"), ""]] + @users.map { |u| [u.display_name, u.id] },
              { selected: @user_id },
              class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
      </div>

      <%# Date from %>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= t("reports.filters.date_from") %></label>
        <%= f.date_field :date_from, value: @date_from,
              class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <%# Date to %>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= t("reports.filters.date_to") %></label>
        <%= f.date_field :date_to, value: @date_to,
              class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
      </div>

      <%# Status (cards only) %>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= t("reports.filters.status") %></label>
        <%= f.select :status,
              [["— #{t("reports.filters.all_statuses")} —", ""],
               [t("reports.statuses.active"), "active"],
               [t("reports.statuses.overdue"), "overdue"],
               [t("reports.statuses.completed"), "completed"],
               [t("reports.statuses.archived"), "archived"]],
              { selected: @status },
              class: "w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white" %>
      </div>

    </div>

    <%= f.hidden_field :generate, value: "1" %>
    <%= f.submit t("reports.generate"),
          class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-6 py-2 rounded-lg cursor-pointer transition-colors" %>

  <% end %>

  <%# Results %>
  <% if @results %>
    <%= render "reports/#{@report_type}_results" %>
  <% end %>

</div>
